APP_NAME="Sistema de Chamados"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://SEU-PROJETO.vercel.app
APP_KEY=base64:GERAR_COM_PHP_ARTISAN_KEY_GENERATE_SHOW

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=SEU_HOST
DB_PORT=3306
DB_DATABASE=SEU_BANCO
DB_USERNAME=SEU_USUARIO
DB_PASSWORD=SUA_SENHA
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=cookie
CACHE_STORE=array
QUEUE_CONNECTION=sync

ADMIN_USERNAME=SEU_ADMIN
ADMIN_PASSWORD=SUA_SENHA_ADMIN

# Se quiser anexos persistentes na Vercel, configure um bucket S3:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
